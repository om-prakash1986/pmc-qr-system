<?xml version="1.0"?>
<configuration>
  <!-- ══════════════════════════════════════════════════════════
       PMC Smart QR Card System — Web.config
       Place this file in the ROOT of your IIS application folder
       (same folder as all the .ashx handler files)
       [Recycle Trigger: Loaded new DLL]
       ══════════════════════════════════════════════════════════ -->
  <connectionStrings>
    <!--
      ⚠️  CHANGE THESE VALUES to match your SQL Server setup:
          Server     = your SQL Server hostname or IP
          Database   = PTax  (or your actual DB name)
          User Id    = your SQL login
          Password   = your SQL password

      Example for Windows Auth (no username/password):
        connectionString="Server=.\SQLEXPRESS;Database=PTax;Integrated Security=True;"
    -->
	  <!-- <add name="nagar_nigam" connectionString="Data Source=localhost;Initial Catalog=PRDADatabase;Integrated Security=True" providerName="System.Data.SqlClient"/> -->
	  <add name="PTax" connectionString="Server=ws241.win.arvixe.com;Database=pmc_sparrow_data;User ID=pmc_user;Password=pmc@#*2023;Trusted_Connection=False;pooling=true;Max Pool Size=50000;" providerName="System.Data.SqlClient"/>
	  <!-- <add name="PTax1" connectionString="Server=ws241.win.arvixe.com;Database=PMC_patna;User ID=isspl;Password=misspl@#*2024;Trusted_Connection=False;pooling=true;Max Pool Size=50000;" providerName="System.Data.SqlClient"/> -->
	  <!-- <add name="PTax" connectionString="Server=localhost;Database=PTax;User Id=sa;Password=YourPasswordHere;TrustServerCertificate=True;MultipleActiveResultSets=True;" providerName="System.Data.SqlClient"/>-->
  </connectionStrings>
  <appSettings>
    <!-- PMC SMS Gateway Credentials — msdgweb.mgov.gov.in (DLT) -->
    <!-- ⚠️  If you have a dedicated QR-portal SMS account, replace with those credentials. -->
    <add key="SMS_Username"      value="BIHAREDISTRICT-pmc" />
    <add key="SMS_Password"      value="pmcpat@#*2018" />
    <add key="SMS_SenderId"      value="BRGOVT" />
    <add key="SMS_SecureKey"     value="f2475cb7-0406-4ca8-8e93-ebb16800d159" />
    <!-- ⚠️  Replace the value below with the DLT-approved Template ID for your OTP message -->
    <add key="SMS_OTPTemplateId" value="1307161770553497695" />
    <!-- Razorpay Payment Gateway Key (Defaults to standard Razorpay test key) -->
    <add key="RazorpayKeyId"      value="rzp_test_DwNn8bSgBfVskq" />
  </appSettings>
  <system.web>
    <!-- Target .NET Framework 4.x -->
    <compilation debug="true" targetFramework="4.7.2"/>
    <httpRuntime targetFramework="4.7.2" maxRequestLength="10240" executionTimeout="120"/>
    <!-- Session state (required by CitizenPortal.ashx) -->
    <sessionState mode="InProc" cookieless="false" timeout="30"/>
    <!-- Custom errors off for debugging — set to On in production -->
    <customErrors mode="Off"/>
    <!-- Allow large JSON responses -->
    <pages validateRequest="false"/>
  </system.web>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="Redirect QR Scans to Portal" stopProcessing="true">
          <match url="^qr/([a-zA-Z0-9\-]+)$" />
          <action type="Redirect" url="/CitizenTaxPortal.aspx?token={R:1}" redirectType="Found" />
        </rule>
      </rules>
    </rewrite>
    <!-- ─── CORS Headers ──────────────────────────────────── -->
    <!-- These allow the admin dashboard HTML file (opened from
         a local path or different origin) to call the API.    -->
    <httpProtocol>
      <customHeaders>
        <add name="Access-Control-Allow-Origin" value="*"/>
        <add name="Access-Control-Allow-Methods" value="GET, POST, OPTIONS"/>
        <add name="Access-Control-Allow-Headers" value="Content-Type, X-Admin-Token"/>
      </customHeaders>
    </httpProtocol>
    <!-- Disable directory browsing -->
    <directoryBrowse enabled="false"/>
    <!-- Default document (optional, for root URL) -->
    <defaultDocument>
      <files>
        <clear/>
        <add value="index.html"/>
      </files>
    </defaultDocument>
    <!-- Security: block direct browsing of sensitive files -->
    <security>
      <requestFiltering>
        <fileExtensions>
          <remove fileExtension=".sql"/>
          <add fileExtension=".sql" allowed="false"/>
        </fileExtensions>
      </requestFiltering>
    </security>
  </system.webServer>
  <!-- Runtime binding redirects for ASP.NET -->
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0"/>
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>